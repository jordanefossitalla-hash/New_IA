APP_NAME=Document Ingestion Platform
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=true
CELERY_LOG_LEVEL=INFO
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=20
OCR_LANGUAGES=fra+eng
EXTRACTION_MIN_TEXT_CHARS=30
EXTRACTION_MIN_ALPHA_RATIO=0.5
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BATCH_SIZE=50
OPENAI_EMBEDDING_MAX_RETRIES=5
OPENAI_EMBEDDING_RETRY_BASE_DELAY=1.0

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=ingestion
POSTGRES_USER=ingestion_user
POSTGRES_PASSWORD=ingestion_password
DATABASE_URL=postgresql+psycopg://ingestion_user:ingestion_password@db:5432/ingestion

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

API_PREFIX=/api/v1
